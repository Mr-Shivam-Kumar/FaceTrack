# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database Configuration ───────────────────────────────────────────────────
# For online mode, replace with your MongoDB Atlas connection string:
# e.g., mongodb+srv://<username>:<password>@cluster.mongodb.net/attendance_system
MONGO_URI=mongodb://localhost:27017/attendance_system

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_secure_long_random_secret_key_in_production
JWT_EXPIRE=7d

# ─── File Upload Limits ────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ─── CORS Whitelist ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (production mode only)
# e.g., https://my-attendance-portal.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173

# ─── Client Configurations (Vite) ─────────────────────────────────────────────
# Set these on your client build/hosting platform (e.g. Vercel, Netlify)
# VITE_API_BASE_URL=https://your-backend-api.herokuapp.com/api
# VITE_SOCKET_URL=https://your-backend-api.herokuapp.com
